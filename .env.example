# Copy this file to .env.local and fill in real values for local development.
# In production (Vercel), set these as environment variables in the project settings.

# Resend API key (https://resend.com/api-keys). Required for the inquiry
# form to send lead-notification and confirmation emails. Without it, the
# server action logs a warning and skips email delivery.
RESEND_API_KEY=

# The "From" address used for outgoing emails. Must be on a domain verified
# with Resend. Falls back to Resend's shared onboarding address for testing.
RESEND_FROM_EMAIL="RENOMA <onboarding@resend.dev>"

# The business inbox that should receive new inquiry notifications.
INQUIRY_NOTIFICATION_EMAIL=

# The canonical production URL, used for metadata, sitemap, and OG tags.
NEXT_PUBLIC_SITE_URL=https://renoma.de

# Public-facing contact email and service area shown in the footer. Both
# are omitted (never faked) if left unset — see src/components/site-footer.tsx.
CONTACT_EMAIL=
SERVICE_AREA=
